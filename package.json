{
  "name": "spec-reviewer",
  "displayName": "spec-reviewer-extension",
  "description": "This is an extension built to review your specs in journey of Spec Driven Development",
  "version": "0.0.1",
  "publisher": "DeekshaZeroDay",
  "engines": {
    "vscode": "^1.112.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onCommand:spec-reviewer.reviewSpec"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "spec-reviewer.reviewSpec",
        "title": "Review Spec"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.15.2"
  }
}
